# Veles Configuration
# Copy this file to .env and adjust as needed

# Default Neo4j instance
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=veles_local
NEO4J_DATABASE=neo4j

# Ollama — use Docker OR point to local installation
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# Infrastructure mode: "docker" or "local" for each service
VELES_NEO4J_MODE=docker
VELES_OLLAMA_MODE=docker

# Embedding dimensions (nomic-embed-text = 768)
EMBEDDING_DIMENSIONS=768

# Chunking configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Default brain name
VELES_DEFAULT_BRAIN=default

# --- Multi-Brain Configuration ---
# Each brain gets its own Neo4j instance for full data isolation.
# Configure additional brains by setting VELES_BRAIN_<NAME>_URI, etc.
# The <NAME> is uppercase, hyphens become underscores.
#
# Example: "work" brain on a separate Neo4j instance (port 7688):
# VELES_BRAIN_WORK_URI=bolt://localhost:7688
# VELES_BRAIN_WORK_USERNAME=neo4j
# VELES_BRAIN_WORK_PASSWORD=veles_work
# VELES_BRAIN_WORK_DATABASE=neo4j
#
# Example: "personal" brain on yet another instance (port 7689):
# VELES_BRAIN_PERSONAL_URI=bolt://localhost:7689
# VELES_BRAIN_PERSONAL_USERNAME=neo4j
# VELES_BRAIN_PERSONAL_PASSWORD=veles_personal
# VELES_BRAIN_PERSONAL_DATABASE=neo4j
#
# Then use the brain parameter in tools:
#   veles_add --brain work "meeting notes..."
#   veles_search --brain personal "recipe for..."
